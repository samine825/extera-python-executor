                on_click=self._add_new_bind
            ),
            Divider()
        ]

        count = int(self.get_setting(self.BIND_COUNT_KEY, "0"))

        for i in range(count):
            cmd_key = f"{self.BIND_CMD_PREFIX}{i}"
            code_key = f"{self.BIND_CODE_PREFIX}{i}"

            cmd = self.get_setting(cmd_key, f".cmd{i}")
            code = self.get_setting(code_key, "")
            code_preview = (code[:60] + "...") if len(code) > 60 else code

            settings.extend([
                Header(text=f"Бинд #{i+1} — {cmd}"),
                Input(
                    key=cmd_key,
                    text="Команда",
                    default=cmd,
                    subtext="пример: .test"
                ),
                Input(
                    key=code_key,
                    text="Код",
                    default="""print("world")""",
                    
                ),
                Text(
                    text="Удалить",
                    icon="msg_delete_filled",
                    red=True,
                    on_click=partial(self._delete_bind, i)
                ),
                Divider()
            ])

        return settings